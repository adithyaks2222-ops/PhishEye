{
  "manifest_version": 3,
  "name": "PhishEye",
  "version": "0.1.0",
  "description": "Browser phishing detection extension under the JARVX cybersecurity ecosystem.",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PhishEye"
  }
}